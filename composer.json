{
  "name": "fr3on/magento2-healthz",
  "description": "Health check endpoints for Magento 2 — liveness, readiness, and detail probes",
  "type": "magento2-module",
  "license": "MIT",
  "authors": [
    {
      "name": "fr3on",
      "email": "ahmed@0x200.com",
      "homepage": "https://0x200.com"
    }
  ],
  "keywords": [
    "magento2",
    "magento",
    "health",
    "healthcheck",
    "kubernetes",
    "liveness",
    "readiness",
    "probe",
    "docker",
    "devops",
    "monitoring"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.magento.com/"
    }
  ],
  "require": {
    "php": ">=8.1",
    "magento/framework": ">=102.0.0",
    "magento/module-store": ">=101.0.0",
    "magento/module-backend": ">=101.0.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpmd/phpmd": "^2.15"
  },
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "Fr3on\\Healthz\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Fr3on\\Healthz\\Test\\": "Test/"
    }
  },
  "extra": {
    "map": [
      [
        "*",
        "Fr3on/Healthz"
      ]
    ]
  },
  "config": {
    "allow-plugins": {
      "magento/composer-dependency-version-audit-plugin": true
    }
  }
}